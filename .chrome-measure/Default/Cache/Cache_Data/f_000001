  border-radius: 6px;
  overflow: hidden;
  cursor: pointer;
  transition: all 0.2s ease;
  z-index: 10;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.browser-search-engine-selector:hover {
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(var(--accent-a), 0.5);
}

.browser-search-engine-selector img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.browser-search-engine-dropdown {
  position: absolute;
  left: 8px;
  top: calc(100% + 8px);
  background: rgba(10, 10, 12, 0.98);
  border: 1px solid rgba(var(--accent-a), 0.3);
  border-radius: 8px;
  padding: 8px;
  min-width: 180px;
  z-index: 100;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(12px);
}

.browser-search-engine-option {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 6px;
  cursor: pointer;
  transition: all 0.2s ease;
  color: rgba(255, 255, 255, 0.85);
}

.browser-search-engine-option:hover {
  background: rgba(var(--accent-a), 0.2);
  color: rgba(255, 255, 255, 1);
}

.browser-search-engine-option img {
  width: 20px;
  height: 20px;
  border-radius: 4px;
  object-fit: cover;
}

.browser-search-engine-option span {
  font-size: 0.9rem;
  font-weight: 500;
}
.toggle { position: relative; width: 56px; height: 30px; }
.toggle input { opacity: 0; width: 0; height: 0; }
.toggle-slider { width: 100%; height: 100%; border-radius: 999px; background: rgba(255,255,255,0.12); display: block; position: relative; transition: background .45s var(--hover-ease), box-shadow var(--hover-glow-duration) var(--hover-ease); cursor: pointer; }
.toggle-slider::after { content: ''; position: absolute; top: 3px; left: 3px; width: 24px; height: 24px; border-radius: 999px; background: #fff; box-shadow: 0 2px 8px rgba(0,0,0,0.3); transition: transform .18s ease; }
.toggle:hover .toggle-slider { box-shadow: var(--hover-glow); }
.toggle input:checked + .toggle-slider { background: linear-gradient(90deg, white, white); box-shadow: var(--hover-glow); }
.toggle input:checked + .toggle-slider::after { transform: translateX(26px); }
.toggle input:focus-visible + .toggle-slider { outline: 2px solid white; outline-offset: 2px; }
.settings-range { width: 180px; height: 6px; -webkit-appearance: none; appearance: none; background: rgba(255,255,255,0.12); border-radius: 3px; outline: none; cursor: pointer; }
.settings-range::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%; background: linear-gradient(90deg, white, white); cursor: pointer; box-shadow: 0 0 0 1px rgba(var(--accent-a), 0.82), 0 0 14px rgba(var(--accent-a), 0.48), 0 0 30px rgba(var(--accent-b), 0.30); transition: transform .32s var(--hover-ease), box-shadow var(--hover-glow-duration) var(--hover-ease); }
.settings-range::-webkit-slider-thumb:hover { transform: scale(1.15); box-shadow: var(--hover-glow-strong); }
.settings-range::-moz-range-thumb { width: 18px; height: 18px; border-radius: 50%; background: linear-gradient(90deg, white, white); cursor: pointer; border: none; box-shadow: 0 0 0 1px rgba(var(--accent-a), 0.82), 0 0 14px rgba(var(--accent-a), 0.48), 0 0 30px rgba(var(--accent-b), 0.30); }
.settings-value { min-width: 50px; text-align: right; font-size: .85rem; font-weight: 600; color: var(--soft); font-variant-numeric: tabular-nums; }
.settings-select { min-width: 180px; max-width: 280px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); background: rgba(2,2,2,0.5); color: rgba(255,255,255,0.7); padding: 10px 12px; font-size: .9rem; cursor: pointer; transition: color .3s ease; }
.settings-select:hover { color: rgba(255,255,255,1); }
.settings-select:focus { outline: none; color: rgba(255,255,255,1); }
.settings-text { min-width: 180px; max-width: 280px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); background: rgba(2,2,2,0.5); color: rgba(255,255,255,0.7); padding: 10px 12px; font-size: .9rem; transition: color .3s ease; }
.settings-text:hover { color: rgba(255,255,255,1); }
.settings-text:focus { outline: none; color: rgba(255,255,255,1); }
.settings-text::placeholder { color: rgba(255,255,255,0.35); }
.segmented { display: flex; gap: 6px; }
.segmented button { padding: 8px 14px; border-radius: 8px; border: none; background: transparent; color: var(--soft); font-size: .88rem; font-weight: 500; cursor: pointer; transition: color .3s ease; }
.segmented button:hover { color: rgba(255,255,255,0.9); }
.segmented button.active { color: rgba(255,255,255,1); font-weight: 600; }
.settings-note { margin-top: 8px; padding: 12px 16px; border-radius: 12px; background: rgba(2,2,2,0.3); border: 1px solid rgba(2,2,2,0.6); font-size: .8rem; color: var(--soft); line-height: 1.5; }
.settings-animated-row { animation: slideDown .25s ease; }
@keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
.settings-about-card { padding: 20px; text-align: center; }
.settings-about-card strong { display: block; font-size: 1.25rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
.settings-about-card p { color: var(--muted); font-size: .92rem; margin-bottom: 16px; }
.settings-about-meta { display: flex; justify-content: center; gap: 16px; flex-wrap: wrap; }
.settings-about-meta span { font-size: .8rem; font-weight: 600; color: var(--soft); padding: 6px 12px; border-radius: 999px; background: rgba(2,2,2,0.5); text-transform: uppercase; letter-spacing: .08em; }
.settings-reset { width: 100%; margin-top: 8px; padding: 12px 20px; border-radius: 12px; border: none; background: rgba(2,2,2,0.5); color: var(--soft); font-size: .9rem; font-weight: 600; cursor: pointer; transition: color .45s var(--hover-ease), background .45s var(--hover-ease), box-shadow var(--hover-glow-duration) var(--hover-ease); }
.settings-reset:hover { background: rgba(2,2,2,0.8); color: #fff; box-shadow: var(--hover-glow); }

/* ── Custom Select ─────────────────────────── */
.settings-custom-select {
  position: relative;
  min-width: 180px;
  max-width: 280px;
  font-family: 'Commissioner', sans-serif;
  font-weight: 300;
}

.settings-custom-select-trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 10px 12px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(2, 2, 2, 0.5);
  color: rgba(255, 255, 255, 0.7);
  font-size: 0.9rem;
  cursor: pointer;
  transition: color 0.3s ease, border-color 0.3s ease;
  font-family: inherit;
  font-weight: inherit;
  text-align: left;
}

.settings-custom-select-trigger:hover {
  color: rgba(255, 255, 255, 1);
  border-color: rgba(255, 255, 255, 0.2);
}

.settings-custom-select-trigger:focus-visible {
  outline: 2px solid rgba(255, 255, 255, 0.5);
  outline-offset: 2px;
}

.settings-custom-select-chevron {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.settings-custom-select.open .settings-custom-select-chevron {
  transform: rotate(180deg);
}

.settings-custom-select-options {
  position: absolute;
  top: calc(100% + 4px);
  left: 0;
  right: 0;
  background: rgba(10, 10, 15, 0.96);
  backdrop-filter: blur(25px) saturate(130%);
  -webkit-backdrop-filter: blur(25px) saturate(130%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  overflow: hidden;
  z-index: 100;
  max-height: 0;
  opacity: 0;
  transition: max-height 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.25s ease;
}

.settings-custom-select.open .settings-custom-select-options {
  max-height: 300px;
  opacity: 1;
}

.settings-custom-select-option {
  width: 100%;
  text-align: left;
  padding: 10px 12px;
  border: none;
  background: transparent;
  color: rgba(255, 255, 255, 0.55);
  font-size: 0.88rem;
  cursor: pointer;
  transition: background 0.2s ease, color 0.2s ease;
  font-family: inherit;
  font-weight: inherit;
}

.settings-custom-select-option:hover {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 1);
}

.settings-custom-select-option.selected {
  color: rgba(255, 255, 255, 1);
  background: rgba(255, 255, 255, 0.04);
}

.settings-custom-select-option:focus-visible {
  outline: 2px solid rgba(255, 255, 255, 0.4);
  outline-offset: -2px;
}

/* ── Custom URL Row ────────────────────────── */
.settings-custom-url-row {
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease, margin 0.3s ease;
}

/* ============================================================
   INFO PAGE STYLES
   ============================================================ */
.info-page {
  padding: 40px 0 80px;
  font-family: 'Commissioner', sans-serif;
  font-weight: 300;
}
.info-wrap {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

/* ── Hero ──────────────────────────────────── */
.info-hero {
  text-align: center;
  padding: 48px 32px 36px;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(25px) saturate(130%);
  -webkit-backdrop-filter: blur(25px) saturate(130%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 24px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}
.info-hero h1 {
  margin: 0 0 12px;
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 300;
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 1.1;
}
.info-hero .tagline {
  margin: 0 auto 16px;
  max-width: 560px;
  font-size: clamp(1rem, 1.8vw, 1.2rem);
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.5;
}
.info-hero p {
  margin: 0 auto 28px;
  max-width: 580px;
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.6;
}

/* ── Stats ─────────────────────────────────── */
.info-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.info-stat {
  padding: 18px 16px;
  text-align: center;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(25px) saturate(130%);
  -webkit-backdrop-filter: blur(25px) saturate(130%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}
.info-stat strong {
  display: block;
  font-size: 2rem;
  font-weight: 300;
  color: #fff;
  line-height: 1;
  margin-bottom: 4px;
}
.info-stat span {
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

/* ── Feature Grid ──────────────────────────── */
.info-features {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12px;
}
.info-feature {
  padding: 22px;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(25px) saturate(130%);
  -webkit-backdrop-filter: blur(25px) saturate(130%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 18px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.info-feature:hover {
  transform: translateY(-2px);
}
.info-feature .icon {
  display: block;
  font-size: 1.5rem;
  margin-bottom: 10px;
}
.info-feature h3 {
  margin: 0 0 6px;
  font-size: 0.92rem;
  font-weight: 300;
  color: #fff;
}
.info-feature p {
  margin: 0;
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.4);
  line-height: 1.5;
}

/* ── Bottom Bar ────────────────────────────── */
.info-bottom {
  text-align: center;
  padding: 22px 24px;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(25px) saturate(130%);
  -webkit-backdrop-filter: blur(25px) saturate(130%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 18px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}
.info-bottom .version {
  font-size: 0.88rem;
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 4px;
}
.info-bottom p {
  margin: 0;
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.3);
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1100px) {
  .settings-window-body { grid-template-columns: 1fr; }
  .settings-sidebar { border-right: none; border-bottom: 0; min-height: auto; }
  .settings-panels { border-left: 0; }
  .info-stats { grid-template-columns: 1fr; }
  .info-features { grid-template-columns: repeat(2, 1fr); }
  .game-detail-hero { grid-template-columns: 1fr; align-items: start; }
  .game-actions { justify-content: flex-start; }
}
@media (max-width: 880px) {
  .hero { margin-left: 0; width: 100%; min-height: auto; padding-top: 18px; }
  #mainContent { margin-left: 0; width: 100%; padding: 12px 16px 90px; }
  .sidebar-navbar { width: 100%; height: auto; flex-direction: row; padding: 8px; border-right: 0; border-bottom: 1px solid var(--line); }
  .nav-icons, .nav-settings { flex-direction: row; } .nav-divider { display: none; }
  .info-stats { grid-template-columns: 1fr; }
  .info-features { grid-template-columns: 1fr; }
  .info-hero { padding: 28px 20px; }
  .info-wrap { gap: 16px; }
  .settings-row { flex-direction: column; align-items: flex-start; gap: 12px; }
  .settings-control { width: 100%; justify-content: space-between; }
  .settings-range { width: 100%; max-width: none; }
  .settings-select, .settings-text { max-width: none; width: 100%; }
  .segmented { width: 100%; justify-content: center; }
}
