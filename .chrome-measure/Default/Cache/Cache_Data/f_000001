}

@keyframes gameLoadSpin {
  to {
    transform: rotate(360deg);
  }
}

/* Games Page Loading Spinner */
.games-page-loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  transition: opacity 0.5s ease;
}

.games-page-loading-overlay.hidden {
  opacity: 0;
  pointer-events: none;
}

.games-page-loading-spinner {
  width: 60px;
  height: 60px;
  border: 3px solid rgba(var(--accent-a), 0.2);
  border-top-color: rgba(var(--accent-a), 0.8);
  border-radius: 50%;
  animation: gameLoadSpin 1s linear infinite;
  box-shadow: 0 0 20px rgba(var(--accent-a), 0.3), 0 0 40px rgba(var(--accent-b), 0.2);
}

/* ============================================================
   ONBOARDING FLOW STYLES
   ============================================================ */
.onboarding-flow {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000000;
  z-index: 100000;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.onboarding-container {
  width: 100%;
  max-width: 500px;
  padding: 40px;
  position: relative;
}

.onboarding-step {
  display: none;
  flex-direction: column;
  align-items: center;
  text-align: center;
  animation: onboardingStepFadeIn 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}

.onboarding-step.active {
  display: flex;
}

@keyframes onboardingStepFadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.onboarding-step.exit {
  animation: onboardingStepFadeOut 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

@keyframes onboardingStepFadeOut {
  to {
    opacity: 0;
    transform: translateY(-20px);
  }
}

/* Step 1: Orbit Welcome */
.onboarding-logo {
  margin-bottom: 60px;
}

.onboarding-logo-text {
  font-family: 'Raleway', sans-serif;
  font-size: 5.5rem;
  font-weight: 400;
  color: #ffffff;
  letter-spacing: 0.06em;
  display: inline-block;
  visibility: hidden;
}

.onboarding-logo-text .letter {
  opacity: 0;
  display: inline-block;
}

@keyframes flickQuick {
  0%   { opacity: 0; }
  3%   { opacity: 0.9; }
  4%   { opacity: 0; }
  9%   { opacity: 0.95; }
  10%  { opacity: 0; }
  16%  { opacity: 1; }
  100% { opacity: 1; }
}

@keyframes flickStutter {
  0%   { opacity: 0; }
  2%   { opacity: 0.85; }
  3%   { opacity: 0; }
  7%   { opacity: 0.9; }
  8%   { opacity: 0; }
  14%  { opacity: 0.95; }
  15%  { opacity: 0; }
  22%  { opacity: 1; }
  100% { opacity: 1; }
}

@keyframes flickGlitch {
  0%   { opacity: 0; }
  1%   { opacity: 0.9; }
  2%   { opacity: 0; }
  4%   { opacity: 0.95; }
  5%   { opacity: 0; }
  7%   { opacity: 0.8; }
  8%   { opacity: 0; }
  11%  { opacity: 0.9; }
  12%  { opacity: 0; }
  16%  { opacity: 0.95; }
  17%  { opacity: 0; }
  22%  { opacity: 1; }
  100% { opacity: 1; }
}

@keyframes flickUnstable {
  0%   { opacity: 0; }
  2%   { opacity: 0.9; }
  3%   { opacity: 0; }
  8%   { opacity: 0.95; }
  9%   { opacity: 0; }
  15%  { opacity: 0.85; }
  16%  { opacity: 0; }
  23%  { opacity: 0.95; }
  24%  { opacity: 0; }
  32%  { opacity: 1; }
  100% { opacity: 1; }
}

@keyframes flickLong {
  0%   { opacity: 0; }
  1%   { opacity: 0.85; }
  2%   { opacity: 0; }
  4%   { opacity: 0.9; }
  5%   { opacity: 0; }
  8%   { opacity: 0.75; }
  9%   { opacity: 0; }
  13%  { opacity: 0.9; }
  14%  { opacity: 0; }
  18%  { opacity: 0.85; }
  19%  { opacity: 0; }
  24%  { opacity: 0.95; }
  25%  { opacity: 0; }
  31%  { opacity: 1; }
  100% { opacity: 1; }
}

.onboarding-button {
  padding: 12px 48px;
  border-radius: 24px;
  border: none;
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  font-weight: 300;
  cursor: pointer;
  transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s ease, box-shadow 0.3s ease;
  backdrop-filter: blur(10px);
  outline: none;
  position: relative;
}

.onboarding-button:hover:not(:disabled) {
  transform: scaleX(1.03);
  background: rgba(var(--accent-a), 0.15);
  box-shadow: 0 0 12px rgba(var(--accent-a), 0.18), 0 0 24px rgba(var(--accent-a), 0.10);
}

/* Get Started button: static aurora glow + hover particle burst */
#getStartedBtn {
  transition: opacity 0.6s ease, transform 0.25s ease-out, background 0.25s ease-out;
}

#getStartedBtn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: inherit;
  z-index: -1;
  pointer-events: none;
  box-shadow:
    0 0 8px 2px rgba(255, 255, 255, 0.04),
    0 0 20px 8px rgba(var(--accent-a), 0.04),
    0 0 40px 20px rgba(var(--accent-a), 0.02);
}

#getStartedBtn:hover:not(:disabled) {
  transform: scaleX(1.04);
  background: rgba(var(--accent-a), 0.05);
  box-shadow: none;
}

.onboarding-button:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.onboarding-button.secondary {
  background: transparent;
  border: none;
}

.onboarding-button.secondary:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.08);
  transform: none;
  box-shadow: 0 0 12px rgba(var(--accent-a), 0.18), 0 0 24px rgba(var(--accent-a), 0.10);
}

/* Step 2: Username Setup */
.onboarding-title {
  font-family: 'Raleway', sans-serif;
  font-size: 2rem;
  font-weight: 400;
  color: #ffffff;
  margin: 0 0 16px 0;
  letter-spacing: 0.05em;
}

.onboarding-description {
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.7);
  margin: 0 0 32px 0;
  line-height: 1.6;
  max-width: 400px;
}

.onboarding-input {
  width: 100%;
  max-width: 320px;
  padding: 16px 20px;
  border-radius: 12px;
  border: 1px solid rgba(255, 255, 255, 0.15);
  background: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  font-weight: 400;
  outline: none;
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  backdrop-filter: blur(10px);
  margin-bottom: 24px;
  text-align: center;
}

.onboarding-input::placeholder {
  color: rgba(255, 255, 255, 0.4);
}

.onboarding-input:focus {
  border-color: rgba(var(--accent-a), 0.5);
  background: rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 20px rgba(var(--accent-a), 0.15);
}

/* Step 3: Theme Selection */
.onboarding-themes {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14px;
  margin-bottom: 32px;
  width: 100%;
  max-width: 520px;
}

.onboarding-theme-card {
  padding: 20px;
  border-radius: 10px;
  border: 2px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.03);
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  text-align: left;
  position: relative;
  overflow: hidden;
}

.onboarding-theme-card:hover {
  transform: translateY(-2px);
  border-color: rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.05);
}

.onboarding-theme-card.selected {
  border-color: rgba(var(--accent-a), 0.6);
  background: rgba(var(--accent-a), 0.1);
  box-shadow: 0 0 30px rgba(var(--accent-a), 0.2);
}

.onboarding-theme-name {
  font-family: 'Raleway', sans-serif;
  font-size: 1rem;
  font-weight: 400;
  color: #ffffff;
  margin: 0 0 8px 0;
  letter-spacing: 0.03em;
}

.onboarding-theme-graphic {
  width: 80px;
  height: 80px;
  margin: 0 auto 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.onboarding-theme-graphic .onboarding-theme-icon {
  width: 80px;
  height: 80px;
  object-fit: contain;
  display: block;
}

.onboarding-theme-preview {
  width: 100%;
  height: 40px;
  border-radius: 8px;
  margin-top: 12px;
  position: relative;
  overflow: hidden;
}

.onboarding-theme-preview::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--theme-a), var(--theme-b));
  opacity: 0.8;
}

/* Step 4: Audio Preferences */
.onboarding-actions {
  display: flex;
  gap: 16px;
  margin-top: 32px;
}

.onboarding-actions .onboarding-button {
  flex: 1;
  min-width: 120px;
}

/* Step 5: Welcome */
.onboarding-welcome-message {
  font-family: 'Raleway', sans-serif;
  font-size: 1.5rem;
  font-weight: 400;
  color: rgba(var(--accent-a), 0.9);
  margin: 0 0 16px 0;
  line-height: 1.5;
  letter-spacing: 0.03em;
  animation: welcomeMessageFadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  opacity: 0;
  transform: translateY(10px);
}

@keyframes welcomeMessageFadeIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.onboarding-step#onboardingStep5 .onboarding-description {
  animation: welcomeDescriptionFadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.2s forwards;
  opacity: 0;
  transform: translateY(10px);
}

@keyframes welcomeDescriptionFadeIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============================================================
   SETTINGS PAGE STYLES
   ============================================================ */
.settings-page {
  padding: 24px 0 80px;
}
.settings-window {
  border: 1px solid rgba(255,255,255,0.002);
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.01);
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
  box-shadow: var(--shadow), 0 0 60px rgba(var(--accent-a), 0.08), 0 0 100px rgba(var(--accent-b), 0.05), inset 0 0 40px rgba(var(--accent-a), 0.03), 0 0 20px rgba(var(--accent-a), 0.15), 0 0 40px rgba(var(--accent-b), 0.1);

  /* Never resize the settings window/page when switching panels */
  height: calc(100vh - 120px);
  max-height: calc(100vh - 120px);
  overflow: hidden;
}

.settings-window-header {
  padding: 18px 24px;
  border-bottom: none;
  background: transparent;
  flex-shrink: 0;
}
.settings-window-header h2 {
  margin: 0; font-size: 1.4rem; font-weight: 700; color: #fff;
  background: linear-gradient(90deg, white, white);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  font-family: 'Nunito', sans-serif;
  font-weight: 400;
}

.settings-window-body {
  display: flex;
  align-items: stretch;
  height: 100%;
  min-height: 0; /* critical for inner flex scrolling */
  overflow: hidden;
}





/* settings sidebar uses its own padding; remove stray/invalid block */

.settings-nav-item {
  text-align: left;
  border-radius: 14px;
  border: 0;
  background: transparent;
  color: rgba(var(--text-rgb, 245,247,255), 0.72);
  padding: 12px 14px;
  cursor: pointer;
  transition: color .25s ease;
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  position: relative;
}
.settings-nav-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 0;
  background: rgb(var(--accent-a));
  border-radius: 0 2px 2px 0;
  transition: height .2s ease;
}
.settings-nav-item:hover {
  /* simple, subtle text lightening only */
  color: rgba(255,255,255,0.92);
}
.settings-nav-item.active {
  border: 0;
  background: transparent;
  color: rgba(255,255,255,1);
}
.settings-nav-item.active::before {
  height: 20px;
}
.settings-nav-left {
  display:flex;
  align-items:center;
  gap:12px;
  min-width:0;
}
.settings-nav-icon svg { display:block; }
.settings-nav-icon { flex:0 0 auto; }
.settings-nav-label { font-size: .95rem; font-weight: 600; letter-spacing: -.01em; white-space: nowrap; overflow:hidden; text-overflow: ellipsis; }
.settings-nav-hint { display: none; }
.settings-panels {
  flex: 1;
  width: 100%;
  min-width: 0;
  padding: 24px 28px;
  overflow-y: auto;
  height: 100%;
  border-left: none;
  position: relative;
}

.settings-panels::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 1px;
  background: linear-gradient(180deg, transparent 0%, rgba(var(--accent-a), 0.15) 20%, rgba(var(--accent-b), 0.12) 50%, rgba(var(--accent-a), 0.15) 80%, transparent 100%);
  box-shadow: 0 0 20px rgba(var(--accent-a), 0.1), 0 0 40px rgba(var(--accent-b), 0.08);
}

/* clean themed scrollbar for settings content */
.settings-panels {
  scrollbar-width: thin;
  scrollbar-color: rgba(var(--accent-a), 0.5) transparent;
}

.settings-panels::-webkit-scrollbar {
  width: 6px;
}

.settings-panels::-webkit-scrollbar-track {
  background: transparent;
}

.settings-panels::-webkit-scrollbar-thumb {
  background: rgba(var(--accent-a), 0.5);
  border-radius: 999px;
}

.settings-panels::-webkit-scrollbar-thumb:hover {
  background: rgba(var(--accent-a), 0.7);
}

.settings-panels::-webkit-scrollbar-thumb:active {
  background: rgba(var(--accent-a), 0.9);
}

.settings-panels::-webkit-scrollbar-button {
  display: none;
}

.settings-panel { display: none; animation: panelSlideIn .3s ease; }
.settings-panel.active { display: block; }
@keyframes panelSlideIn { from { opacity: 0; transform: translateX(-20px); } to { opacity: 1; transform: translateX(0); } }
.settings-panel-head {
  display: none;
}
.settings-panel-head h3,
.settings-panel-head p {
  display: none;
}
.settings-panel-body { display: grid; gap: 16px; }
.settings-row { display: flex; justify-content: space-between; gap: 14px; align-items: center; padding: 14px 0; border-bottom: 1px solid rgba(2,2,2,0.6); }
.settings-row:last-of-type { border-bottom: 0; }
.settings-row-left { flex: 1; min-width: 0; width: 100%; }
.settings-control { flex: 0 0 auto; }

.settings-row-left h4 { margin: 0 0 4px; font-size: .98rem; font-weight: 600; color: #fff; font-family: 'Elms Sans', sans-serif; font-weight: 300; }
.settings-row-left p { margin: 0; color: var(--soft); font-size: .85rem; line-height: 1.4; font-family: 'Elms Sans', sans-serif; font-weight: 300; }
.settings-control { display: flex; align-items: center; gap: 12px; flex: 0 0 auto; }

/* ==================== Browser Search Engine Selector ==================== */

