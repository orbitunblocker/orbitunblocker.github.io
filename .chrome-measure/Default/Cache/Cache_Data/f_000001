}

.browser-menu-separator {
  height: 1px;
  background: rgba(255, 255, 255, 0.05);
  margin: 5px 10px;
}

.browser-menu-toggle {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.browser-menu-toggle-label {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.78);
}

.browser-menu-toggle-switch {
