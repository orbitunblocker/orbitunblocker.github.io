  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  font-variant-numeric: tabular-nums;
  font-feature-settings: "tnum";
}

.game-notch-battery {
  display: flex;
  align-items: center;
  margin-right: 12px;
}

.game-notch-battery svg {
  width: 28px;
  height: 20px;
  fill: currentColor;
  color: rgba(255, 255, 255, 0.7);
}

.game-notch-icon {
  width: 52px;
  height: 52px;
  border-radius: 14px;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.12);
  background: rgba(2, 2, 2, 0.5);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.35), 0 0 16px rgba(var(--accent-a), 0.15), 0 0 32px rgba(var(--accent-b), 0.08);
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.game-notch-icon:hover {
  border-color: rgba(var(--accent-a), 0.4);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.35), 0 0 20px rgba(var(--accent-a), 0.25), 0 0 40px rgba(var(--accent-b), 0.12);
}

.game-notch-icon img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.game-notch-title h3 {
  margin: 0;
  font-size: 1.5rem;
  font-weight: 700;
  font-family: 'Quicksand', sans-serif;
  font-weight: 400;
  color: #ffffff;
  text-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.game-notch-right {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
  user-select: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
}

.game-notch-btn,
.game-notch-control {
  width: 42px;
  height: 42px;
  border-radius: 8px;
  border: none;
  background: rgba(2, 2, 2, 0.5);
  color: rgba(255, 255, 255, 0.85);
  user-select: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  backdrop-filter: blur(14px);
}

.game-notch-btn:hover,
.game-notch-control:hover {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3), 0 0 16px rgba(var(--accent-a), 0.2), 0 0 32px rgba(var(--accent-b), 0.1);
}

.game-notch-btn svg,
.game-notch-control svg {
  width: 20px;
  height: 20px;
  fill: currentColor;
}

.game-notch-toggle {
  position: absolute;
  bottom: -16px;
  left: 50%;
  transform: translateX(-50%);
  width: 40px;
  height: 20px;
  background: rgba(2, 2, 2, 0.98);
  border: none;
  border-radius: 0 0 20px 20px;
  display: none;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 1.5s cubic-bezier(0.22, 1, 0.36, 1);
  backdrop-filter: blur(20px);
  z-index: 10;
}

.game-notch:not(.minimized) ~ .game-notch-toggle {
  display: none;
}

.game-notch.minimized ~ .game-notch-toggle {
  display: flex;
}

.game-notch.minimized ~ .game-notch-toggle {
  position: fixed;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  bottom: auto;
  width: 80px;
  height: 24px;
  background: rgba(2, 2, 2, 0.98);
  border: none;
  border-radius: 0 0 20px 20px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), 0 0 24px rgba(var(--accent-a), 0.15), 0 0 48px rgba(var(--accent-b), 0.08);
  z-index: 1001;
}

.game-notch-toggle:hover {
  background: rgba(255, 255, 255, 0.08);
}

.game-notch-toggle svg {
  width: 18px;
  height: 18px;
  fill: currentColor;
  color: rgba(var(--accent-a), 0.7);
}

.game-notch.minimized ~ .game-notch-toggle svg {
  width: 24px;
  height: 24px;
}

.game-embed-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #000000;
}

.game-embed {
  width: 100%;
  height: 100%;
  border: none;
  display: block;
  background: #000000;
  user-select: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
}

/* Game Loading Animation */
.game-loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
  transition: opacity 0.5s ease;
}

.game-loading-overlay.hidden {
  opacity: 0;
  pointer-events: none;
}

.game-loading-spinner {
  width: 60px;
  height: 60px;
