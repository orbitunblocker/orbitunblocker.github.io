:root {
  --nav-height: 72px;
  --sidebar-width: 72px;
  --bg: #000000;
  --panel: rgba(2,2,2,0.7);
  --panel-2: rgba(2,2,2,0.4);
  --line: rgba(2,2,2,1.4);
  --text: #f5f7ff;
  --muted: #dfe6f5;
  --soft: #b8c2d7;
  --shadow: 0 20px 48px rgba(0,0,0,0.52);
  --accent-a: 255,255,255;
  --accent-b: 255,255,255;
  --accent-c: 255,255,255;
  --hover-ease: cubic-bezier(0.22, 1, 0.36, 1);
  --hover-glow-duration: .65s;
  --hover-glow: 0 0 12px rgba(var(--accent-a), 0.65), 0 0 24px rgba(var(--accent-b), 0.48), 0 0 44px rgba(var(--accent-c), 0.28);
  --hover-glow-strong: 0 0 16px rgba(var(--accent-a), 0.72), 0 0 32px rgba(var(--accent-b), 0.54), 0 0 55px rgba(var(--accent-c), 0.30);
  color-scheme: dark;
}

* { box-sizing: border-box; }
html, body {
  margin: 0;
  width: 100%;
  min-height: 100%;
  overflow-x: hidden;
  font-family: Inter, Arial, sans-serif;
  background: var(--bg);
  color: var(--text);
}

/* Hide Native Scrollbars Globally */
::-webkit-scrollbar {
  width: 0px;
  height: 0px;
  display: none;
}

::-webkit-scrollbar-track {
  display: none;
}

::-webkit-scrollbar-thumb {
  display: none;
}

::-webkit-scrollbar-button {
  display: none;
}

* {
  scrollbar-width: none;
  -ms-overflow-style: none;
}

/* Custom Scrollbar Component */
.custom-scrollbar {
  position: fixed;
  top: 0;
  right: 8px;
  width: 6px;
  height: 100vh;
  z-index: 9999;
  pointer-events: none;
  opacity: 0;
  display: none;
  visibility: hidden;
}

body.on-homepage .custom-scrollbar {
  display: none !important;
  opacity: 0 !important;
  visibility: hidden !important;
}

.custom-scrollbar-thumb {
  position: absolute;
  right: 0;
  width: 6px;
  background: rgba(var(--accent-a), 0.5);
  border-radius: 999px;
  pointer-events: auto;
  cursor: pointer;
  transition: background 0.2s ease;
}

.custom-scrollbar-thumb:hover {
  background: rgba(var(--accent-a), 0.7);
}

.custom-scrollbar-thumb:active {
  background: rgba(var(--accent-a), 0.9);
}

body {
  position: relative;
  background: #000000;
}

body.smooth-scroll {
  scroll-behavior: smooth;
}

canvas, .noise { position: fixed; inset: 0; pointer-events: none; z-index: 0; }

/* Page Switching Animations */
#mainContent {
  animation: pageFadeIn 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes pageFadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
canvas { opacity: 0.35; }
.blur-orb { position: fixed; border-radius: 999px; filter: blur(120px); mix-blend-mode: screen; opacity: 1; transition: background 0.5s ease; pointer-events: none; z-index: 0; }
.orb1 { width: 1200px; height: 600px; background: rgba(var(--accent-a), 0.7); bottom: -300px; left: 50%; transform: translateX(-50%); }
.orb2 { display: none; }

body.hide-orbs .orb1 {
  opacity: 0;
  visibility: hidden;
}
.noise { opacity: 0.04; background-image: repeating-radial-gradient(circle at 0 0, transparent 0, rgba(255,255,255,0.45) 1px, transparent 2px); background-size: 6px 6px; }

/* Homepage Entrance Animations */
.sidebar-navbar {
  position: fixed; inset: 0 auto 0 0; width: var(--sidebar-width); z-index: 100;
  display: flex; flex-direction: column; align-items: center; padding: 4px 0 14px;
  background: #030303; border-right: 1px solid var(--line);
  box-shadow: 12px 0 40px rgba(0,0,0,0.35); backdrop-filter: blur(18px);
  animation: sidebarSlideIn 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  opacity: 0;
  transform: translateX(-20px);
}

@keyframes sidebarSlideIn {
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.hero-logo,
.hero-clock,
.hero-notifications {
  opacity: 0;
  transition: opacity 2s cubic-bezier(0.4, 0, 0.2, 1);
}

.hero.reveal .hero-logo,
.hero.reveal .hero-clock,
.hero.reveal .hero-notifications {
  opacity: 1;
}


.nav-logo {
  width: 90px; height: 90px; border-radius: 50%; display: grid; place-items: center;
  background: transparent;
  border: none; box-shadow: none; overflow: hidden;
  cursor: pointer; transition: transform .32s var(--hover-ease);
  position: relative;
  z-index: 10;
}
.nav-logo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scale(1.5);
  user-select: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  pointer-events: none;
  -webkit-user-drag: none;
  -moz-user-drag: none;
}
.nav-logo:hover {
  transform: scale(1.1);
}
.password-logo img {
  width: 120px;
  height: auto;
  user-select: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  pointer-events: none;
  -webkit-user-drag: none;
  -moz-user-drag: none;
}

/* ============================================================
   INTRO SCREEN STYLES
   ============================================================ */
.intro-screen {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #000;
  opacity: 1;
}

.intro-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0px;
  position: relative;
}

.intro-logo {
  opacity: 0;
  animation: fadeIn 1s ease forwards;
  margin-top: -50px;
}

.intro-logo img {
  width: 800px;
  height: auto;
  display: block;
  user-select: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  pointer-events: none;
  -webkit-user-drag: none;
  -moz-user-drag: none;
}

.intro-title {
  font-size: 4rem;
  font-weight: 300;
  letter-spacing: 0.4em;
  margin: 0;
  position: absolute;
  top: 65%;
  left: 51%;
  transform: translateX(-50%);
  color: #fff;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  font-style: normal;
  opacity: 0;
  animation: fadeIn 1s ease 0.5s forwards;
}

.intro-button {
  padding: 14px 56px;
  font-size: 1rem;
  font-weight: 200;
  letter-spacing: 0.15em;
  color: #fff;
  background: #0a0a0a;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  transition: box-shadow 0.3s ease, transform 0.3s ease, background 0.2s ease;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  opacity: 0;
  animation: fadeIn 1s ease 1s forwards;
  position: absolute;
  top: 79%;
}

.intro-button:hover {
  background: #222;
  transform: scale(1.05);
  box-shadow: 0 0 15px rgba(255, 255, 255, 0.15);
}

.intro-button:active {
  transform: scale(1.05);
}

.intro-screen.fade-out {
  animation: fadeOut 0.4s ease forwards;
}

.intro-screen.fade-out .intro-content {
  animation: fadeOutContent 0.3s ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

@keyframes fadeOutContent {
  from {
    opacity: 1;
    transform: scale(1);
  }
  to {
    opacity: 0;
    transform: scale(0.95);
  }
}
.nav-divider { width: 38px; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent); margin: 8px 0; }
.nav-icons, .nav-settings { display: flex; flex-direction: column; gap: 8px; }
.nav-icon {
  width: 48px;
  height: 48px;
  border-radius: 10px;
  display: grid;
  place-items: center;

  color: rgba(245,247,255,0.86);
  cursor: pointer;
  border: none;

  position: relative;
  overflow: hidden;

  /* resting: icon only (no filled background) */
  background: transparent;

  transform: translateY(0) scale(1);
  transition:
    transform .32s var(--hover-ease),
    color .45s var(--hover-ease),
    background .35s var(--hover-ease),
    box-shadow var(--hover-glow-duration) var(--hover-ease);
}



.nav-icon svg {
  width: 22px;
  height: 22px;
  position: relative;
  z-index: 1;
}

.nav-icon:hover {
  /* no enlargement; only smooth fill-in */
  transform: none;
  color: #ffffff;
  background: rgba(var(--accent-a), 0.15);
  /* no glow */
  box-shadow: none;
}

.nav-icon.active {
  /* stay filled when selected */
  background: rgba(var(--accent-a), 0.25);
  color: #ffffff;
  /* no glow */
  box-shadow: none;
}






.hero {
  position: relative; z-index: 2; margin-left: var(--sidebar-width); width: calc(100vw - var(--sidebar-width));
  min-height: 88vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;
  padding: 28px 22px 12px;
}
.hero-logo {
  width: min(520px, 80vw);
  height: min(520px, 80vw);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-logo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scale(1.25);
  transform-origin: center center;
  user-select: none;
  -webkit-user-select: none;
  -moz-user-select: none;
  -ms-user-select: none;
  pointer-events: none;
  -webkit-user-drag: none;
  -moz-user-drag: none;
}

.hero-clock {
  font-family: 'Chakra Petch', monospace;
  font-weight: 400;
  font-size: clamp(1.4rem, 2.8vw, 2.6rem);
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.45);
  margin-top: max(-80px, -8vw);
  position: relative;
  z-index: 1;
  text-align: center;
  line-height: 1;
  pointer-events: none;
}

/* ── Notification Center ──────────────────── */
.hero-notifications {
  width: min(480px, 88vw);
  margin-top: 18px;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(25px) saturate(130%);
  -webkit-backdrop-filter: blur(25px) saturate(130%);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 20px;
  color: #fff;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
  overflow: hidden;
  cursor: pointer;
  transition:
    max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1),
    opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: max-height;
  font-family: 'Commissioner', sans-serif;
  font-weight: 300;
}

/* ── Shine overlay ─────────────────────────── */
.hero-notifications::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0.06) 0%,
    transparent 50%
  );
  pointer-events: none;
  z-index: 0;
}

/* ── Notification Card ────────────────────── */
.nc-card {
  padding: 14px 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  position: relative;
  z-index: 1;
}

.nc-card:first-child {
  opacity: 1;
  transform: none;
}

.nc-card {
  opacity: 0;
  transform: translateY(6px);
}

.nc-card.visible {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1), transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.nc-card + .nc-card {
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

/* ── Card Header ──────────────────────────── */
.nc-card-header {
  display: flex;
  align-items: center;
  gap: 10px;
}

.nc-icon {
  flex-shrink: 0;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.9rem;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.nc-card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.nc-title {
  font-size: 0.82rem;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.3;
}

.nc-body {
  font-size: 0.72rem;
  color: rgba(255, 255, 255, 0.5);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nc-time {
  flex-shrink: 0;
  font-size: 0.62rem;
  color: rgba(255, 255, 255, 0.3);
  white-space: nowrap;
}

/* ── Card Actions (expand + dismiss) ──────── */
.nc-card-actions {
  position: absolute;
  top: 6px;
  right: 6px;
  display: flex;
  gap: 4px;
  z-index: 2;
}

.nc-dismiss,
.nc-expand-btn {
  width: 18px;
  height: 18px;
  border: none;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 6px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.3);
  padding: 0;
  font-size: 0.42rem;
  line-height: 1;
  transition: color 0.2s ease, background 0.2s ease;
  position: relative;
  overflow: hidden;
}

.nc-dismiss:hover,
.nc-expand-btn:hover {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.5);
}

.nc-expand-btn {
  transition: color 0.2s ease, background 0.2s ease, transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.hero-notifications.expanded .nc-expand-btn {
  transform: rotate(180deg);
}

/* ── Hold-to-clear red fill ────────────────── */
.nc-dismiss::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(200, 40, 40, 0.4);
  border-radius: inherit;
  transform: scaleY(0);
  transform-origin: top center;
  pointer-events: none;
}

@keyframes redFill {
  from { transform: scaleY(0); }
  to   { transform: scaleY(1); }
}

.nc-dismiss.holding::before {
  animation: redFill 2s linear forwards;
}

/* ── Card Footer ──────────────────────────── */
.nc-card-footer {
  display: flex;
  align-items: center;
  gap: 6px;
  padding-top: 2px;
}

.nc-badge {
  display: inline-block;
  font-size: 0.55rem;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.3);
  padding: 2px 6px;
  border-radius: 4px;
  background: rgba(255, 255, 255, 0.04);
}

/* ── Empty State ──────────────────────────── */
.nc-empty {
  font-size: 0.78rem;
  color: rgba(255, 255, 255, 0.12);
  text-align: center;
  padding: 16px 0;
}

/* ── Entrance Animation ───────────────────── */
.nc-card.entering {
  animation: ncFadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes ncFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Browser Engine Styles */
.browser-container {
  position: relative;
  z-index: 2;
  margin-left: var(--sidebar-width);
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: rgba(0, 0, 0, 0.95);
  border-radius: 16px;
  margin: 12px;
  margin-left: calc(var(--sidebar-width) + 12px);
  overflow: hidden;
  border: 1px solid rgba(var(--accent-a), 0.2);
  box-shadow: 0 0 40px rgba(var(--accent-a), 0.15), 0 0 80px rgba(var(--accent-a), 0.08);
}

.browser-tab-bar {
  display: flex;
  align-items: center;
  background: rgba(10, 10, 15, 0.96);
  padding: 6px 10px 0;
  gap: 0;
  flex-shrink: 0;
  border-radius: 16px 16px 0 0;
}

.browser-tabs {
  display: flex;
  gap: 0;
  flex: 1;
  overflow-x: auto;
  scrollbar-width: none;
  align-items: flex-end;
}

.browser-tabs::-webkit-scrollbar {
  display: none;
}

.browser-tab {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 16px;
  border-radius: 8px 8px 0 0;
  background: transparent;
  color: rgba(255, 255, 255, 0.5);
  cursor: pointer;
  font-size: 0.8rem;
  font-weight: 500;
  white-space: nowrap;
  max-width: 200px;
  transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  border: 1px solid rgba(var(--accent-a), 0.08);
  border-bottom: none;
  min-width: 0;
  position: relative;
  margin-right: 0;
}

.browser-tab + .browser-tab::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12px;
  bottom: 12px;
  width: 1px;
  background: rgba(var(--accent-a), 0.1);
}

.browser-tab:hover {
  background: rgba(255, 255, 255, 0.06);
  color: rgba(255, 255, 255, 0.85);
  border-color: rgba(var(--accent-a), 0.25);
}

.browser-tab.active {
  background: #2b2b2b;
  color: #ffffff;
  position: relative;
  z-index: 1;
  border-color: rgba(var(--accent-a), 0.2);
}

.browser-tab.active::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: -1px;
  right: -1px;
  height: 1px;
  background: #2b2b2b;
}

.browser-tab.tab-enter {
  animation: tabEnter 0.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  transform-origin: left center;
}

.browser-tabs.tabs-inserting .browser-tab {
  transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.browser-tab.tab-exit {
  animation: tabExit 0.2s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  pointer-events: none;
  overflow: hidden;
}

.browser-tab.tab-dragging {
  z-index: 10;
  opacity: 0.85;
  cursor: grabbing;
}

.browser-tab.tab-shift {
  transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
}

.browser-tab.tab-drag-over {
  background: rgba(255, 255, 255, 0.1);
}

.browser-tabs.dragging .browser-tab {
  transition: transform 0.2s cubic-bezier(0.22, 1, 0.36, 1);
  user-select: none;
}

@keyframes tabEnter {
  from {
    transform: scaleX(0);
  }
  to {
    transform: scaleX(1);
  }
}

@keyframes tabExit {
  from {
    opacity: 1;
    transform: scaleX(1);
    max-width: 200px;
    padding-left: 16px;
    padding-right: 16px;
  }
  to {
    opacity: 0;
    transform: scaleX(0.85);
    max-width: 0;
    padding-left: 0;
    padding-right: 0;
    margin-right: 0;
  }
}

.browser-tab-title {
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
  min-width: 0;
}

.browser-tab-loader {
  width: 14px;
  height: 14px;
  border: 2px solid rgba(var(--accent-a), 0.4);
  border-top-color: white;
  border-radius: 50%;
  animation: browserSpin 0.6s linear infinite;
  flex-shrink: 0;
}

@keyframes browserSpin {
  to { transform: rotate(360deg); }
}

.browser-tab-close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  border: none;
  background: transparent;
  color: rgba(255, 255, 255, 0.4);
  cursor: pointer;
  border-radius: 6px;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.browser-tab-close:hover {
  background: rgba(255, 255, 255, 0.15);
  color: white;
}

.browser-new-tab-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: 1px solid rgba(var(--accent-a), 0.12);
  background: rgba(255, 255, 255, 0.03);
  color: rgba(255, 255, 255, 0.5);
  cursor: pointer;
  border-radius: 10px;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.browser-new-tab-btn:hover {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  border-color: rgba(var(--accent-a), 0.3);
}

.browser-nav-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  background: rgba(10, 10, 15, 0.96);
  padding: 10px 14px;
  flex-shrink: 0;
  position: relative;
  z-index: 2;
}

.browser-nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border: 1px solid rgba(var(--accent-a), 0.12);
  background: rgba(255, 255, 255, 0.03);
  color: rgba(255, 255, 255, 0.5);
  cursor: pointer;
  border-radius: 10px;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.browser-nav-btn:hover:not(:disabled) {
  background: rgba(255, 255, 255, 0.1);
  color: white;
  border-color: rgba(var(--accent-a), 0.3);
}

.browser-nav-btn:disabled {
  opacity: 0.3;
  cursor: default;
}

.browser-nav-btn svg {
  width: 20px;
  height: 20px;
}

.browser-address-bar-wrapper {
  flex: 1;
  position: relative;
}

.browser-address-bar {
  position: relative;
}

.browser-address-input {
  width: 100%;
  padding: 10px 16px;
  border-radius: 12px;
  border: 1px solid rgba(var(--accent-a), 0.15);
  background: rgba(255, 255, 255, 0.05);
  color: white;
